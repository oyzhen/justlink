{
    "name": "tinylink",
    "version": "0.1.0",
    "license": "MIT",
    "type": "module",
    "packageManager": "yarn@4.16.0",
    "sideEffects": false,
    "exports": {
        "./core": {
            "types": "./dist/core.d.ts",
            "import": "./dist/core.js"
        },
        "./browser": {
            "types": "./dist/browser.d.ts",
            "import": "./dist/browser.js"
        },
        "./node": {
            "types": "./dist/node.d.ts",
            "import": "./dist/node.js"
        },
        "./memory": {
            "types": "./dist/memory.d.ts",
            "import": "./dist/memory.js"
        }
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md",
        "README.zh-CN.md",
        "skills"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vite build && tsc -p tsconfig.build.json && node scripts/fix-decls.cjs",
        "preview": "vite preview",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
        "lint": "eslint . --fix",
        "test": "vitest run --config=vitest.config.ts --coverage && vitest run --config=vitest.browser.config.ts --coverage",
        "test:browser": "vitest run --config=vitest.browser.config.ts --coverage",
        "prepublishOnly": "npm run lint && npm run build && npm test"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.13.2",
        "@vitest/browser": "^4.1.9",
        "@vitest/browser-playwright": "^4.1.9",
        "@vitest/coverage-v8": "4.1.9",
        "eslint": "^10.5.0",
        "happy-dom": "^20.10.5",
        "jsdom": "^29.1.1",
        "playwright": "^1.61.0",
        "prettier": "^3.8.4",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.0.12",
        "vitest": "^4.1.9"
    }
}
